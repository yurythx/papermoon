SECRET_KEY=your-secret-key-here
DEBUG=True
DATABASE_URL=postgres://papermoon:papermoon@postgres:5432/papermoon
REDIS_URL=redis://redis:6379/0
ASAAS_API_KEY=your-asaas-api-key
ASAAS_WEBHOOK_TOKEN=your-asaas-webhook-token
CHATWOOT_API_URL=https://app.chatwoot.com
CHATWOOT_API_KEY=your-chatwoot-api-key
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:3000
SENTRY_DSN=

# JWT RS256 — obrigatório em produção; opcional em dev (local.py auto-gera se ausente).
# Gere um par com: make generate-jwt-keys
# Valores são PEM com \n literal (não quebras de linha reais).
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=

# Production only — habilitar em produção
# DJANGO_SETTINGS_MODULE=core.settings.production
# SECURE_PROXY_SSL_HEADER=HTTP_X_FORWARDED_PROTO,https

# E-mail — MailHog captura tudo localmente (veja http://localhost:8025)
# Em produção, trocar para smtp.EmailBackend e configurar as variáveis abaixo.
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=mailhog
EMAIL_PORT=1025
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=False
DEFAULT_FROM_EMAIL=noreply@papermoon.local

# Frontend URL — used in invitation e-mails
FRONTEND_URL=https://app.papermoon.com.br

# n8n self-hosted provisioner
N8N_API_URL=https://n8n.yourcompany.com
N8N_API_KEY=your-n8n-api-key

# Meta WhatsApp Business API
META_WHATSAPP_TOKEN=your-meta-access-token
META_WABA_ID=your-waba-id

# GLPI self-hosted helpdesk (em breve)
GLPI_API_URL=https://glpi.yourcompany.com
GLPI_APP_TOKEN=your-glpi-app-token
GLPI_USER_TOKEN=your-glpi-user-token

# Zabbix self-hosted monitoring
ZABBIX_API_URL=https://zabbix.yourcompany.com
ZABBIX_API_TOKEN=your-zabbix-api-token

# TrueNAS self-hosted NAS
TRUENAS_API_URL=https://truenas.yourcompany.com
TRUENAS_API_KEY=your-truenas-api-key
TRUENAS_POOL=data

# RustDesk self-hosted remote access
RUSTDESK_API_URL=https://rustdesk.yourcompany.com
RUSTDESK_API_KEY=your-rustdesk-api-key

# Keycloak Identity Provider (SSO)
KEYCLOAK_API_URL=https://keycloak.yourcompany.com
KEYCLOAK_ADMIN_TOKEN=your-keycloak-admin-token

# CrowdSec Console API
CROWDSEC_API_URL=https://app.crowdsec.net/api/v1
CROWDSEC_API_KEY=your-crowdsec-api-key

# Twenty CRM self-hosted
TWENTY_CRM_API_URL=https://crm.yourcompany.com
TWENTY_CRM_API_KEY=your-twenty-api-key

# Papermark self-hosted document sharing
PAPERMARK_API_URL=https://papermark.yourcompany.com
PAPERMARK_API_KEY=your-papermark-api-key

# Plone CMS / intranet
PLONE_API_URL=https://plone.yourcompany.com
PLONE_API_KEY=your-plone-api-key

# Samba file server management API (se utilizado)
SAMBA_API_URL=
SAMBA_API_KEY=

# Windows Server / WAC (Windows Admin Center)
WINDOWS_SERVER_WAC_URL=
WINDOWS_SERVER_WAC_KEY=

# CMS ISR — Next.js revalidação on-demand
# Deve ser igual ao REVALIDATE_SECRET no .env do frontend
REVALIDATE_SECRET=your-revalidate-secret
NEXTJS_INTERNAL_URL=http://nextjs:3000

# Flower (monitoramento de workers Celery)
FLOWER_USER=admin
FLOWER_PASSWORD=your-flower-password

# Telegram — alertas de falhas de provisioners (opcional; deixe vazio para desabilitar)
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALERT_CHAT_ID=
