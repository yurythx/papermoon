# ─────────────────────────────────────────────────────────────────────────────
# PaperMoon — Variaveis de Ambiente de Producao
#
# Copie para .env.production e preencha TODOS os valores marcados com CHANGE-ME.
# NUNCA commite .env.production no git (já está no .gitignore).
#
# Usado por: docker-compose.prod.yml (backend + build do Next.js)
# ─────────────────────────────────────────────────────────────────────────────

# ── Banco de dados ────────────────────────────────────────────────────────────
POSTGRES_DB=papermoon
POSTGRES_USER=papermoon
POSTGRES_PASSWORD=CHANGE-ME-strong-password
# DATABASE_URL deve coincidir com POSTGRES_USER/PASSWORD acima
DATABASE_URL=postgres://papermoon:CHANGE-ME-strong-password@postgres:5432/papermoon

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=CHANGE-ME-redis-password
# REDIS_URL deve coincidir com REDIS_PASSWORD acima
REDIS_URL=redis://:CHANGE-ME-redis-password@redis:6379/0

# ── Django ────────────────────────────────────────────────────────────────────
# Gere com: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=CHANGE-ME-50-char-random-string-here
DEBUG=False
# webhooks.papermoon.example.com e exposto direto ao django-api (sem passar pelo BFF
# do Next.js) só para o endpoint /api/v1/webhooks/asaas/ — ver cloudflared/config.yml.example
ALLOWED_HOSTS=app.papermoon.example.com,webhooks.papermoon.example.com,django-api
CORS_ALLOWED_ORIGINS=https://app.papermoon.example.com

# ── JWT RS256 ─────────────────────────────────────────────────────────────────
# Deixe em branco — o deploy.sh detecta as chaves ausentes e gera (e grava aqui)
# um par RSA-2048 automaticamente antes de rodar migrations. Só preencha à mão
# se quiser fixar/rotacionar uma chave específica (make prod-generate-jwt).
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=

# ── Asaas (gateway de pagamento) ─────────────────────────────────────────────
ASAAS_API_KEY=CHANGE-ME-asaas-production-api-key
ASAAS_WEBHOOK_TOKEN=CHANGE-ME-asaas-webhook-secret

# ── Chatwoot (suporte ao cliente) ─────────────────────────────────────────────
CHATWOOT_API_URL=https://app.chatwoot.com
CHATWOOT_API_KEY=CHANGE-ME-chatwoot-api-key

# ── E-mail (SMTP) ─────────────────────────────────────────────────────────────
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.sendgrid.net
EMAIL_PORT=587
EMAIL_HOST_USER=apikey
EMAIL_HOST_PASSWORD=CHANGE-ME-smtp-password
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=PaperMoon <noreply@papermoon.example.com>
FRONTEND_URL=https://app.papermoon.example.com
# E-mail que receberá notificações de novos cadastros
ADMIN_NOTIFICATION_EMAIL=ops@papermoon.example.com

# ── CMS / ISR revalidation ────────────────────────────────────────────────────
# REVALIDATE_SECRET: token secreto compartilhado entre Django e Next.js para
# invalidar o cache ISR das páginas de serviço imediatamente após edição no admin.
# Gere com: openssl rand -base64 32
REVALIDATE_SECRET=CHANGE-ME-revalidate-secret
# URL interna do Next.js (dentro da rede Docker — não exposta ao público)
NEXTJS_INTERNAL_URL=http://nextjs:3000

# ── Sentry (backend) ──────────────────────────────────────────────────────────
# Obtenha em: sentry.io > Settings > Projects > Client Keys
SENTRY_DSN=https://CHANGE-ME@oXXXXX.ingest.sentry.io/XXXXXX

# ── n8n ──────────────────────────────────────────────────────────────────────
N8N_API_URL=https://n8n.papermoon.example.com
N8N_API_KEY=CHANGE-ME-n8n-api-key

# ── WhatsApp (Meta Cloud API) ─────────────────────────────────────────────────
META_WHATSAPP_TOKEN=CHANGE-ME-meta-access-token
META_WABA_ID=CHANGE-ME-waba-id

# ── GLPI ─────────────────────────────────────────────────────────────────────
GLPI_API_URL=https://glpi.cliente.com.br
GLPI_APP_TOKEN=CHANGE-ME-glpi-app-token
GLPI_USER_TOKEN=CHANGE-ME-glpi-user-token

# ── Zabbix ───────────────────────────────────────────────────────────────────
ZABBIX_API_URL=https://zabbix.cliente.com.br
ZABBIX_API_TOKEN=CHANGE-ME-zabbix-api-token

# ── TrueNAS ──────────────────────────────────────────────────────────────────
# URL interna da instância TrueNAS SCALE (sem barra no final)
TRUENAS_API_URL=https://truenas.infra.interna
# API key gerada em TrueNAS › System › API Keys
TRUENAS_API_KEY=CHANGE-ME-truenas-api-key
# Pool ZFS padrão onde os datasets dos clientes serão criados
TRUENAS_POOL=data

# ── RustDesk Server Pro ───────────────────────────────────────────────────────
# Necessário apenas se você usa RustDesk Server Pro (tem API REST).
# O Server Pro community edition não tem API — o provisionamento será manual.
# URL do seu servidor RustDesk Pro (sem barra no final)
RUSTDESK_API_URL=https://rustdesk.suaempresa.com.br
# API key gerada no painel admin do RustDesk Server Pro
RUSTDESK_API_KEY=CHANGE-ME-rustdesk-api-key

# ── Windows Server (Windows Admin Center) ────────────────────────────────────
# Necessário apenas se o Windows Admin Center (WAC) estiver exposto com API.
# Deixe em branco para provisionamento manual via equipe técnica.
# URL do Windows Admin Center (sem barra no final), ex: https://wac.suaempresa.com.br:6516
WINDOWS_SERVER_WAC_URL=
# Token de autenticação do WAC (gerado em Settings > Access > API)
WINDOWS_SERVER_WAC_KEY=

# ── Samba — Servidor de Arquivos Linux ───────────────────────────────────────
# Necessário apenas se houver endpoint de gerenciamento customizado (ex: Cockpit API).
# Deixe em branco para provisionamento manual via equipe técnica.
# URL da API de gerenciamento Samba (sem barra no final)
SAMBA_API_URL=
# Chave de autenticação da API Samba
SAMBA_API_KEY=

# ── Backup ───────────────────────────────────────────────────────────────────
# Diretório local onde os backups são armazenados (relativo ao APP_DIR)
# Padrão: $APP_DIR/backups  — não precisa alterar normalmente
BACKUP_DIR=

# Cloud sync via rclone (opcional).
# Configure rclone com: rclone config
# Exemplos:
#   BACKUP_RCLONE_REMOTE=b2:meu-bucket/papermoon-backups   (Backblaze B2)
#   BACKUP_RCLONE_REMOTE=s3:meu-bucket/papermoon-backups   (AWS S3)
#   BACKUP_RCLONE_REMOTE=gdrive:papermoon-backups          (Google Drive)
# Deixe vazio para armazenar apenas localmente.
BACKUP_RCLONE_REMOTE=

# Retenção local (em dias). Padrão: 7 daily / 28 weekly / 90 monthly
DAILY_RETENTION=7
WEEKLY_RETENTION=28
MONTHLY_RETENTION=90

# ── Next.js (build-time — ARGs no docker-compose.prod.yml) ───────────────────
# URL pública do site (sem barra no final)
NEXT_PUBLIC_SITE_URL=https://app.papermoon.example.com

# Frontend Sentry DSN (pode ser o mesmo projeto do backend ou um separado)
NEXT_PUBLIC_SENTRY_DSN=https://CHANGE-ME@oXXXXX.ingest.sentry.io/XXXXXX

# Sentry release tracking (opcional — necessário para source maps no CI)
SENTRY_ORG=sua-org
SENTRY_PROJECT=papermoon-frontend
SENTRY_AUTH_TOKEN=
