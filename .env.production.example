# ─────────────────────────────────────────────────────────────────────────────
# PaperMoon — Variáveis de Ambiente de Produção
#
# Como usar:
#   cp .env.production.example .env.production
#   nano .env.production          ← preencha os campos marcados com <<<
#
# Para gerar valores aleatórios use os comandos comentados em cada campo.
# Campos sem <<< já têm valor padrão seguro — só altere se souber o motivo.
# ─────────────────────────────────────────────────────────────────────────────

# ══════════════════════════════════════════════════════════════════════════════
# BLOCO 1 — BANCO DE DADOS (obrigatório)
# ══════════════════════════════════════════════════════════════════════════════

POSTGRES_DB=papermoon
POSTGRES_USER=papermoon

# <<< Gere com: openssl rand -base64 32
POSTGRES_PASSWORD=

# Deve usar os mesmos POSTGRES_USER e POSTGRES_PASSWORD acima
# <<< Substitua <SENHA> pelo mesmo valor de POSTGRES_PASSWORD
DATABASE_URL=postgres://papermoon:<SENHA>@postgres:5432/papermoon

# ══════════════════════════════════════════════════════════════════════════════
# BLOCO 2 — REDIS (obrigatório)
# ══════════════════════════════════════════════════════════════════════════════

# <<< Gere com: openssl rand -base64 24
REDIS_PASSWORD=

# Deve usar o mesmo REDIS_PASSWORD acima
# <<< Substitua <SENHA> pelo mesmo valor de REDIS_PASSWORD
REDIS_URL=redis://:<SENHA>@redis:6379/0

# ══════════════════════════════════════════════════════════════════════════════
# BLOCO 3 — DJANGO (obrigatório)
# ══════════════════════════════════════════════════════════════════════════════

# <<< Gere com: python3 -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=

DEBUG=False

# <<< Substitua SEU_DOMINIO pelo domínio real (ex: papermoon.com.br)
# Formato: sem https://, separado por vírgula, sem espaços
ALLOWED_HOSTS=app.SEU_DOMINIO,webhooks.SEU_DOMINIO,django-api

# <<< Substitua SEU_DOMINIO pelo domínio real
CORS_ALLOWED_ORIGINS=https://app.SEU_DOMINIO

# ══════════════════════════════════════════════════════════════════════════════
# BLOCO 4 — JWT RS256 (deixe em branco — deploy.sh gera automaticamente)
# ══════════════════════════════════════════════════════════════════════════════
#
# O deploy.sh detecta campos vazios e gera um par RSA-2048 automaticamente.
# Só preencha manualmente se quiser fixar uma chave específica.
# Para rotacionar: make prod-generate-jwt

JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=

# ══════════════════════════════════════════════════════════════════════════════
# BLOCO 5 — URLs do SISTEMA (obrigatório)
# ══════════════════════════════════════════════════════════════════════════════

# <<< URL pública do frontend (com https://)
FRONTEND_URL=https://app.SEU_DOMINIO

# URL interna do Next.js dentro da rede Docker — NÃO altere
NEXTJS_INTERNAL_URL=http://nextjs:3000

# <<< URL pública do site para o Next.js (com https://)
NEXT_PUBLIC_SITE_URL=https://app.SEU_DOMINIO

# ══════════════════════════════════════════════════════════════════════════════
# BLOCO 6 — E-MAIL / SMTP (obrigatório para notificações e cadastros)
# ══════════════════════════════════════════════════════════════════════════════
#
# Opções de provedor SMTP gratuito:
#   SendGrid  → EMAIL_HOST=smtp.sendgrid.net  PORT=587  USER=apikey
#   Brevo     → EMAIL_HOST=smtp-relay.brevo.com  PORT=587  USER=seu@email.com
#   Gmail     → EMAIL_HOST=smtp.gmail.com  PORT=587  USER=seu@gmail.com
#                (precisa de App Password em myaccount.google.com/apppasswords)

EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend

# <<< Servidor SMTP
EMAIL_HOST=smtp.sendgrid.net

# <<< Porta (587 para TLS, 465 para SSL)
EMAIL_PORT=587
EMAIL_USE_TLS=True

# <<< Usuário SMTP (para SendGrid use "apikey" como usuário)
EMAIL_HOST_USER=apikey

# <<< Senha ou API Key do provedor SMTP
EMAIL_HOST_PASSWORD=

# <<< E-mail que aparece como remetente
# <<< Substitua SEU_DOMINIO pelo domínio real
DEFAULT_FROM_EMAIL=PaperMoon <noreply@SEU_DOMINIO>

# <<< E-mail do admin que recebe notificações de novos cadastros
ADMIN_NOTIFICATION_EMAIL=admin@SEU_DOMINIO

# ══════════════════════════════════════════════════════════════════════════════
# BLOCO 7 — ASAAS — Gateway de pagamento (obrigatório para faturamento)
# ══════════════════════════════════════════════════════════════════════════════
#
# Obtenha em: asaas.com → Configurações → Integrações → API Keys
# Use a chave de PRODUÇÃO (começa com $aact_...)

# <<< API Key de produção do Asaas
ASAAS_API_KEY=

# <<< Token secreto para validar webhooks do Asaas
# Gere com: openssl rand -hex 32
# Depois cadastre este mesmo valor em: Asaas → Configurações → Webhooks
ASAAS_WEBHOOK_TOKEN=

# ══════════════════════════════════════════════════════════════════════════════
# BLOCO 8 — FLOWER — Monitoramento do Celery (obrigatório)
# ══════════════════════════════════════════════════════════════════════════════

# <<< Usuário e senha para acessar o painel do Flower
FLOWER_USER=admin
# <<< Gere com: openssl rand -base64 16
FLOWER_PASSWORD=

# ══════════════════════════════════════════════════════════════════════════════
# BLOCO 9 — CMS / ISR (obrigatório se usar o módulo CMS)
# ══════════════════════════════════════════════════════════════════════════════
#
# Token compartilhado entre Django e Next.js para invalidar cache de páginas.

# <<< Gere com: openssl rand -base64 32
REVALIDATE_SECRET=

# ══════════════════════════════════════════════════════════════════════════════
# BLOCO 10 — BACKUP (opcional — padrão funciona sem preencher)
# ══════════════════════════════════════════════════════════════════════════════

# Diretório de backups (padrão: ./backups — não precisa alterar)
BACKUP_DIR=

# Retenção local
DAILY_RETENTION=7
WEEKLY_RETENTION=28
MONTHLY_RETENTION=90

# Cloud sync via rclone (opcional)
# Exemplos:
#   b2:meu-bucket/papermoon-backups   (Backblaze B2 — gratuito até 10 GB)
#   s3:meu-bucket/papermoon-backups   (AWS S3)
#   gdrive:papermoon-backups          (Google Drive)
BACKUP_RCLONE_REMOTE=

# ══════════════════════════════════════════════════════════════════════════════
# BLOCO 11 — SENTRY — Monitoramento de erros (opcional mas recomendado)
# ══════════════════════════════════════════════════════════════════════════════
#
# Crie uma conta gratuita em sentry.io, crie um projeto Python e um JavaScript.
# Obtenha o DSN em: Projeto → Settings → Client Keys (DSN)

# Backend
SENTRY_DSN=

# Frontend (pode ser o mesmo projeto ou um separado)
NEXT_PUBLIC_SENTRY_DSN=

# Para source maps no CI (opcional)
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# ══════════════════════════════════════════════════════════════════════════════
# BLOCO 12 — INTEGRAÇÕES EXTERNAS (todos opcionais)
# ══════════════════════════════════════════════════════════════════════════════
# Deixe em branco — o sistema faz graceful fallback (log-only) se não configurado

# ── Chatwoot (suporte ao cliente) ─────────────────────────────────────────────
CHATWOOT_API_URL=https://app.chatwoot.com
CHATWOOT_API_KEY=

# ── n8n (automação de workflows) ──────────────────────────────────────────────
N8N_API_URL=
N8N_API_KEY=

# ── WhatsApp (Meta Cloud API) ─────────────────────────────────────────────────
META_WHATSAPP_TOKEN=
META_WABA_ID=

# ── GLPI (helpdesk) ───────────────────────────────────────────────────────────
GLPI_API_URL=
GLPI_APP_TOKEN=
GLPI_USER_TOKEN=

# ── Zabbix (monitoramento de infraestrutura) ──────────────────────────────────
ZABBIX_API_URL=
ZABBIX_API_TOKEN=

# ── TrueNAS SCALE (storage NAS) ───────────────────────────────────────────────
TRUENAS_API_URL=
TRUENAS_API_KEY=
TRUENAS_POOL=data

# ── RustDesk Server Pro (acesso remoto) ───────────────────────────────────────
RUSTDESK_API_URL=
RUSTDESK_API_KEY=

# ── Windows Admin Center (servidores Windows) ────────────────────────────────
WINDOWS_SERVER_WAC_URL=
WINDOWS_SERVER_WAC_KEY=

# ── Samba / Cockpit (servidor de arquivos Linux) ──────────────────────────────
SAMBA_API_URL=
SAMBA_API_KEY=
