# Internal URL used by Next.js BFF API routes to call Django (server-to-server, never exposed to browser)
# In Docker Compose: http://web:8000/api/v1
# Local dev:         http://localhost:8000/api/v1
DJANGO_INTERNAL_URL=http://localhost:8000/api/v1

# Public base URL for sitemap.xml and robots.txt (used at build/runtime, not exposed to browser as a JS var)
NEXT_PUBLIC_SITE_URL=https://app.papermoon.example.com

# CMS ISR on-demand revalidation (deve ser igual ao REVALIDATE_SECRET do backend)
REVALIDATE_SECRET=your-revalidate-secret

# Sentry — deixar vazio para desativar em desenvolvimento
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=your-sentry-org
SENTRY_PROJECT=papermoon-frontend
SENTRY_AUTH_TOKEN=your-sentry-auth-token
